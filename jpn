// --- 自動擴充邏輯 ---
const generateFullDatabase = () => {
  const result = [];
  ['N5', 'N4', 'N3', 'N2', 'N1'].forEach(level => {
    const baseWords = baseWordDatabase.filter(w => w.level === level);
    for (let i = 0; i < 300; i++) {
      const base = baseWords[i % baseWords.length];
      const isMock = i >= baseWords.length;
      result.push({ ...base, id: `${level}-${i + 1}`, kanji: isMock ? `${base.kanji} ${i + 1}` : base.kanji, isMock });
    }
  });
  ['食物', '設施', '交通'].forEach(level => {
    const baseWords = baseTravelDatabase.filter(w => w.level === level);
    for (let i = 0; i < 100; i++) {
      const base = baseWords[i % baseWords.length];
      const isMock = i >= baseWords.length;
      result.push({ ...base, id: `travel-${level}-${i + 1}`, kanji: isMock ? `${base.kanji} ${i + 1}` : base.kanji, isMock });
    }
  });
  for (let i = 0; i < 100; i++) {
    const base = baseConversationDatabase[i % baseConversationDatabase.length];
    const isMock = i >= baseConversationDatabase.length;
    result.push({ 
      ...base, 
      id: `conv-${i + 1}`, 
      question: { ...base.question, kanji: isMock ? `${base.question.kanji} (情境 ${i + 1})` : base.question.kanji },
      isMock 
    });
  }
  return result;
};

const fullWordDatabase = generateFullDatabase();

const MaskedText = ({ text, isHidden, className }) => {
  const [isRevealed, setIsRevealed] = useState(false);
  useEffect(() => { setIsRevealed(false); }, [isHidden]);

  return (
    <span
      onClick={() => isHidden && setIsRevealed(!isRevealed)}
      className={`${className} transition-all duration-300 ${isHidden && !isRevealed ? 'blur-[6px] bg-slate-200/50 text-transparent select-none cursor-pointer rounded px-1' : ''}`}
    >
      {text}
    </span>
  );
};

