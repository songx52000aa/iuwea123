                            <div>
                              <div className="flex items-center gap-2 mb-1.5">
                                <span className={`text-[10px] font-bold px-2 py-0.5 rounded ${word.answer.speaker === '自己' ? 'bg-blue-100 text-blue-700' : 'bg-rose-100 text-rose-700'}`}>
                                  {word.answer.speaker}
                                </span>
                                <span className="text-slate-400 text-xs">{word.answer.kana}</span>
                              </div>
                              <div className="flex items-start gap-2 mb-1">
                                <div className="text-[17px] font-bold text-slate-800 leading-snug">{word.answer.kanji}</div>
                                <button onClick={() => playAudio(word.answer.kanji)} className="p-1 text-blue-500 bg-blue-50 active:bg-blue-100 rounded-full shrink-0"><Volume2 size={16} /></button>
                              </div>
                              <div className="text-[14px] text-slate-500"><MaskedText text={word.answer.meaning} isHidden={hideMeaning} /></div>
                            </div>
                          </div>
                          <div className="absolute top-3 right-3"><ActionButtons word={word} /></div>
                        </div>
                      </div>
                    );
                  }

                  // 標準單字卡片
                  return (
                    <div key={word.id} className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden relative">
                      <div className={`p-4 pb-3 border-b border-slate-100 flex justify-between items-start ${word.isMock ? 'bg-slate-50' : 'bg-gradient-to-br from-white to-blue-50/50'}`}>
                        <div>
                          <div className="text-blue-500 font-medium text-xs mb-1">{word.kana}</div>
                          <div className="flex items-center gap-2 mb-2">
                            <div className="text-3xl font-black text-slate-800">{word.kanji}</div>
                            <button onClick={() => playAudio(word.kanji)} className="p-2 text-blue-500 active:bg-blue-100 rounded-full transition-colors">
                              <Volume2 size={22} />
                            </button>
                          </div>
                          <div className="text-base font-bold text-emerald-600">
                            <MaskedText text={word.meaning} isHidden={hideMeaning} />
                          </div>
                        </div>
                        <div className="absolute top-3 right-3"><ActionButtons word={word} /></div>
                      </div>
                      <div className="p-4 bg-slate-50/50">
                        <div className="space-y-3">
                          {word.examples.map((ex, idx) => (
                            <div key={idx} className="relative pl-3 border-l-2 border-blue-200">
                              <div className="flex items-start justify-between gap-1 mb-1">
                                <p className="font-medium text-slate-700 text-[14px] leading-snug">{ex.jp}</p>
                                <button onClick={() => playAudio(ex.jp)} className="p-1 text-slate-400 active:text-blue-500 active:bg-blue-50 rounded shrink-0">
                                  <Volume2 size={16} />
                                </button>
                              </div>
                              <p className="text-[13px] text-slate-500"><MaskedText text={ex.zh} isHidden={hideMeaning} /></p>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>
                  );
                })}

                {hasMore && (
                  <button onClick={handleLoadMore} className="w-full py-3 mt-4 bg-blue-50 text-blue-600 font-bold rounded-xl active:bg-blue-100 transition-colors flex items-center justify-center gap-2">
                    <span>載入更多 ({visibleCount} / {displayWords.length})</span>
                    <ChevronDown size={18} />
                  </button>
                )}
                {!hasMore && displayWords.length > 0 && <div className="text-center py-6 text-slate-400 text-sm">已經到底囉！🎉</div>}
              </div>
            )}
          </div>
        )}
      </main>

      {/* --- App 底部導覽列 (Bottom Tab Bar) --- */}
      <nav className="fixed bottom-0 w-full bg-white border-t border-slate-200 z-20 pb-safe">
        <div className="max-w-md mx-auto flex justify-around">
          <button 
            onClick={() => setCurrentView('main_menu')} 
            className={`flex flex-col items-center justify-center w-full py-3 ${['main_menu', 'jlpt_menu', 'travel_menu', 'N5', 'N4', 'N3', 'N2', 'N1', '食物', '設施', '交通', '日常對話'].includes(currentView) ? 'text-blue-600' : 'text-slate-400 hover:text-slate-600'}`}
          >
            <Home size={24} className="mb-1" />
            <span className="text-[10px] font-bold">探索學習</span>
          </button>
          
          <button 
            onClick={() => setCurrentView('favorites')} 
            className={`flex flex-col items-center justify-center w-full py-3 relative ${currentView === 'favorites' ? 'text-yellow-500' : 'text-slate-400 hover:text-slate-600'}`}
          >
            <div className="relative">
              <Star size={24} className="mb-1" fill={currentView === 'favorites' ? "currentColor" : "none"} />
              {favorites.length > 0 && (
                <span className="absolute -top-1 -right-2 bg-rose-500 text-white text-[9px] font-black w-4 h-4 rounded-full flex items-center justify-center border-2 border-white">
                  {favorites.length > 99 ? '99+' : favorites.length}
                </span>
              )}
            </div>
            <span className="text-[10px] font-bold">單字庫</span>
          </button>
        </div>
      </nav>
    </div>
  );
}
